meta {
  name: Chat
  type: http
  seq: 2
  doc: Ask a question about your LeetCode profile. Uses RAG (Pinecone + GPT-4o-mini).
}

post {
  url: {{baseUrl}}/api/v1/rag/chat
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "question": "What topics am I weakest in?"
  }
}
