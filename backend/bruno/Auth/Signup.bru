meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/signup
  body: json
  auth: none
}

body:json {
  {
    "name": "Your Name",
    "email": "you@example.com",
    "password": "yourpassword"
  }
}

script:post-response {
  const body = res.getBody();
  if (body.accessToken) bru.setVar("accessToken", body.accessToken);
  if (body.refreshToken) bru.setVar("refreshToken", body.refreshToken);
}
