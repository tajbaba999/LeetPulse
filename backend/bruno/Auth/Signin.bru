meta {
  name: Signin
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/signin
  body: json
  auth: none
}

body:json {
  {
    "email": "my@tajworks.com",
    "password": "Random@123"
  }
}

script:post-response {
  const body = res.getBody();
  if (body.accessToken) bru.setVar("accessToken", body.accessToken);
  if (body.refreshToken) bru.setVar("refreshToken", body.refreshToken);
}
