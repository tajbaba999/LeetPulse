NODE_ENV=development
PORT=3000

# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# NeonDB connection string (get it from neon.tech dashboard → your project → Connection string)
# Make sure to append ?sslmode=require at the end
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/grindlytics?sslmode=require

# Redis (docker-compose spins this up automatically)
REDIS_URL=redis://localhost:6379
# Production Redis (e.g. Upstash):
# REDIS_URL=rediss://default:password@your-upstash-endpoint:6380

# Pinecone (vector database for AI embeddings)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=dsa-tracker

# OpenAI (for embeddings + AI chat)
OPENAI_API_KEY=your-openai-api-key
