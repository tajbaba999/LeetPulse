    "@prisma/client": "^7.8.0",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.0",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "graphql-request": "^7.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "leetcode-query": "^2.0.1",
    "morgan": "^1.10.1",
    "openai": "^6.45.0",
